# ─────────────────────────────────────────────
#  MC AFK Dashboard — Environment Variables
# ─────────────────────────────────────────────

# Server
PORT=15022
NODE_ENV=production

# Dashboard Auth (change these in production!)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=changeme123
JWT_SECRET=super-secret-jwt-key-change-this-in-production-please

# Security
CORS_ORIGIN=http://localhost:5173

# Database
DB_PATH=./data/mcafk.db

# Log directory
LOG_DIR=./logs

# Session expiry (in seconds, default 24h)
JWT_EXPIRES_IN=86400
